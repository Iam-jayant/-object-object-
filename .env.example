# MediProof Environment Variables
# Copy this file to .env and fill in your values

# ── Smart Contract (deployed on Monad Testnet) ─────────────────────────────
VITE_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS_HERE

# ── Pinata IPFS ────────────────────────────────────────────────────────────
VITE_PINATA_API_KEY=your_pinata_api_key
VITE_PINATA_SECRET_API_KEY=your_pinata_secret_key

# ── Monad Network (defaults below are correct for testnet) ────────────────
VITE_RPC_URL=https://testnet-rpc.monad.xyz
VITE_CHAIN_ID=10143

# ── The Graph (optional — enables full Analytics dashboard) ───────────────
# Format: https://api.studio.thegraph.com/query/<USER_ID>/mediproof/v0.0.1
VITE_GRAPH_URL=

# ── Push Protocol (optional — enables recall notifications) ───────────────
# After creating a channel at https://app.push.org, set:
VITE_PUSH_CHANNEL_ADDRESS=0xYOUR_PUSH_CHANNEL_ADDRESS
# 'staging' for testnet, 'prod' for mainnet
VITE_PUSH_ENV=staging

# ── Hardhat Deployment (server-side only, never expose in frontend) ────────
# DO NOT prefix with VITE_ — these are for scripts/deploy.js only
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key_without_0x
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc.monad.xyz
REPORT_GAS=false
